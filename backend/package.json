{
  "name": "xkx-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node-pg-migrate -m src/db/migrations up",
    "migrate:create": "node-pg-migrate -m src/db/migrations create"
  },
  "dependencies": {
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "nanoid": "^5.0.7",
    "pg": "^8.12.0",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "@types/ws": "^8.5.11",
    "node-pg-migrate": "^7.5.2",
    "nodemon": "^3.1.4",
    "tsx": "^4.16.0",
    "typescript": "^5.5.3"
  }
}
